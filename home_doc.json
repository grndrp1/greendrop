              "_key": "a1",
              "_type": "block",
              "children": [
                {
                  "_type": "span",
                  "text": "We service a wide range of vehicles, from compact cars to light trucks, ensuring that no matter your vehicle type, we’ve got the expertise to keep it running smoothly."
                }
              ],
              "style": "normal"
            }
          ],
          "question": "What types of vehicles do you work on?"
