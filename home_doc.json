              "_type": "block",
              "children": [
                {
                  "_type": "span",
                  "text": "Yes, we offer easy online booking to help you schedule your service at a time that works best for you."
                }
              ],
              "style": "normal"
            }
          ],
          "question": "Can I book an appointment online?"
        },
