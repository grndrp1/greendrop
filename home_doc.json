3 medium-3\" id=\"1074628637\" data-anim-extended=\"eyJkZXNrdG9wIjp7InRyaWdnZXIiOiJ2aWV3cG9ydCIsImFuaW1hdGlvbiI6ImZhZGVJbkNvbWJvIiwicmV2ZXJzZSI6ZmFsc2UsImludGVuc2l0eSI6MSwidmlld3BvcnRUaHJlc2hvbGRzIjp7InRvcCI6IjUwJSIsImJvdHRvbSI6IjAlIn0sImRlbGF5IjowLCJkdXJhdGlvbiI6MSwiZGlyIjoiaW4tcGxhY2UifX0=\"> <div class=\"u_1629495280 dmNewParagraph\" data-element-type=\"paragraph\" data-version=\"5\" id=\"1629495280\" style=\"transition: none 0s ease 0s; text-align: left; display: block;\"> <h4 class=\"text-align-center\"><span style=\"color: var(--color_3); display: unset;\">Membership</span></h4> \n</div> \n <div class=\"u_1049326090 dmNewParagraph\" data-element-type=\"paragraph\" data-version=\"5\" id=\"1049326090\" style=\"transition: none 0s ease 0s; text-align: left; display: block;\"><p class=\"text-align-left\"><span class=\"\" style=\"display: initial; color: rgb(255, 255, 255);\"><span style=\"display: initial; color: rgb(255, 255, 255);\">Keep your car running longer with</span> \n</span><a href=\"https://www.greendropgarage.com/memberships-old\" runtime_url=\"/memberships\" type=\"page\" style=\"display: initial; font-weight: bold;\">memberships</a><span class=\"\" style=\"display: initial; color: rgb(255, 255, 255);\"> <span style=\"display: initial; color: rgb(255, 255, 255);\">starting at $21/month, offering unlimited oil changes, safety checks, and essential replacements.</span></span></p></div> \n</div> \n <div class=\"u_1384015023 dmRespCol small-12 large-3 medium-3\" id=\"1384015023\" data-anim-extended=\"eyJkZXNrdG9wIjp7InRyaWdnZXIiOiJ2aWV3cG9ydCIsImFuaW1hdGlvbiI6ImZhZGVJbkNvbWJvIiwicmV2ZXJzZSI6ZmFsc2UsImludGVuc2l0eSI6MSwidmlld3BvcnRUaHJlc2hvbGRzIjp7InRvcCI6IjUwJSIsImJvdHRvbSI6IjAlIn0sImRlbGF5IjowLCJkdXJhdGlvbiI6MSwiZGlyIjoiaW4tcGxhY2UifX0=\"> <div class=\"u_1776105624 dmNewParagraph\" data-element-type=\"paragraph\" data-version=\"5\" id=\"1776105624\" style=\"transition: none 0s ease 0s; text-align: left; display: block;\"> <h4 class=\"text-align-center\"><span style=\"color: var(--color_3); display: unset;\">GReen Shop</span></h4> \n</div> \n <div class=\"u_1429665853 dmNewParagraph\" data-element-type=\"paragraph\" data-version=\"5\" id=\"1429665853\" style=\"transition: none 0s ease 0s; text-align: left; display: block;\"><p class=\"text-align-left\"><span style=\"color: rgb(255, 255, 255); display: initial;\">As a certified B-Corp, we deliver eco-friendly service with re-refined oils, enzyme-based cleaners, and a commitment to sustainability.</span></p></div> \n</div> \n <div class=\"u_1645900699 dmRespCol small-12 large-3 medium-3\" id=\"1645900699\" data-anim-extended=\"eyJkZXNrdG9wIjp7InRyaWdnZXIiOiJ2aWV3cG9ydCIsImFuaW1hdGlvbiI6ImZhZGVJbkNvbWJvIiwicmV2ZXJzZSI6ZmFsc2UsImludGVuc2l0eSI6MSwidmlld3BvcnRUaHJlc2hvbGRzIjp7InRvcCI6IjUwJSIsImJvdHRvbSI6IjAlIn0sImRlbGF5IjowLCJkdXJhdGlvbiI6MSwiZGlyIjoiaW4tcGxhY2UifX0=\"> <div class=\"u_1710735553 dmNewParagraph\" data-element-type=\"paragraph\" data-version=\"5\" id=\"1710735553\" style=\"transition: none 0s ease 0s; text-align: left; display: block;\"> <h4 class=\"text-align-center\"><span style=\"color: var(--color_3); display: unset;\">Flat Fixes</span></h4> \n</div> \n <div class=\"u_1831656857 dmNewParagraph\" data-element-type=\"paragraph\" data-version=\"5\" id=\"1831656857\" style=\"transition: none 0s ease 0s; text-align: left; display: block;\"><p class=\"text-align-left\"><span style=\"display: initial; color: rgb(255, 255, 255);\">Stay safe on the road with free tire inspections and flat fixes anytime, helping you catch potential issues before they turn into costly emergencies.</span></p></div> \n</div> \n</div> \n</div> \n</div> \n</div> \n</div> \n <div class=\"dmRespRow u_1526563601\" id=\"1526563601\"> <div class=\"dmRespColsWrapper\" id=\"1323480224\"> <div class=\"u_1693601166 dmRespCol small-12 medium-6 large-6\" id=\"1693601166\"> <div class=\"u_1961335955 dmRespRow\" id=\"1961335955\"> <div class=\"dmRespColsWrapper\" id=\"1647127861\"> <div class=\"dmRespCol large-12 medium-12 small-12 u_1326617505\" id=\"1326617505\"> <div class=\"u_1334487830 dmNewParagraph\" data-element-type=\"paragraph\" data-version=\"5\" id=\"1334487830\" data-styletopreserve=\"{\" background-image\":\"\"}\"=\"\" data-diy-text=\"\"> <h2 class=\"m-text-align-left text-align-left\"><span style=\"display: initial; color: var(--color_2);\">Vehicles We Service</span></h2> \n</div> \n <div class=\"u_1026546104 dmDividerWrapper clearfix\" data-element-type=\"dDividerId\" data-layout=\"divider-style-1\" data-widget-version=\"2\" id=\"1026546104\" layout=\"divider-gradient-line\"><hr class=\"dmDivider\" style=\"border-width:2px; border-top-style:solid; color:grey;\" id=\"1150361205\"></div> \n <div class=\"dmNewParagraph\" data-element-type=\"paragraph\" data-version=\"5\" id=\"1320818181\" new-inline-bind-applied=\"true\" data-diy-text=\"\"> <h3 style=\"letter-spacing: normal;\"><span class=\"\" style=\"display: initial;\"><span style=\"display: initial;\">Servicing All Makes and Models with Expert Precision in</span> \n</span> \n<span class=\"inline-data-binding\" data-encoded-value=\"UG9ydGxhbmQgJmFtcDsgVmFuY291dmVy\" data-inline-binding=\"site_text.region/county\">Portland &amp; Vancouver</span><span style=\"display: initial;\"><span class=\"ql-cursor\"></span></span></h3> \n</div> \n <div class=\"dmNewParagraph u_1454869436\" data-element-type=\"paragraph\" data-version=\"5\" id=\"1454869436\" style=\"text-align: left; display: block;\"><p><span style=\"display: initial;\">At Green Drop Garage, we believe that every vehicle deserves quality care, which is why our ASE-certified technicians are equipped to service all makes and models, from daily drivers and family SUVs to eco-conscious hybrids and electric vehicles. Our team’s expertise spans a wide range of vehicle types, so whether you’re driving a classic sedan, a rugged truck, or a high-efficiency hybrid, you can count on Green Drop Garage to handle your maintenance and repairs with precision. We’re committed to delivering consistent, reliable results across our six locations in Portland, OR, and Vancouver, WA.</span></p><p><br></p><p><span style=\"display: initial;\">We approach every vehicle with the same eco-conscious commitment that defines Green Drop Garage. Our services use re-refined oils, lower-impact chemicals, and sustainable practices to ensure that our work protects the environment as much as it protects your vehicle. By servicing all vehicle makes and models while incorporating environmentally friendly techniques, we make it easier for our community to choose green auto care without compromising on quality or safety.</span></p></div> \n <a data-display-type=\"block\" class=\"u_1125216068 align-center shopgenie-book-appt-btn dmButtonLink dmWidget dmWwr default dmOnlyButton dmDefaultGradient\" file=\"false\" data-element-type=\"dButtonLinkId\" id=\"1125216068\" title=\"Make an Appointment Online\" lock-element-for-editing=\"true\"> <span class=\"iconBg\" aria-hidden=\"true\" id=\"1170671546\"> <span class=\"icon hasFontIcon icon-star\" id=\"1455517184\"></span> \n</span> \n <span class=\"text\" id=\"1477887480\">Book Your Service</span> \n</a> \n</div> \n</div> \n</div> \n</div> \n <div class=\"u_1355689861 dmRespCol small-12 large-undefined medium-undefined large-0 medium-0 dmSectionNoParallax medium-6 large-6 hide-for-small\" id=\"1355689861\" data-gallery-bg=\"eyJzbGlkZXMiOlsiaHR0cHM6Ly9pcnAuY2RuLXdlYnNpdGUuY29tLzE2MmZmNGUzL2RtczNyZXAvbXVsdGkvc2VjdGlvbi1iZzExLWFic3RyYWN0LXNoYXBlcy01NGMwYjRjMC5zdmciXX0=\"> <div class=\"u_1438849442 imageWidget align-center\" data-element-type=\"image\" data-widget-type=\"image\" id=\"1438849442\"><img src=\"https://lirp.cdn-website.com/162ff4e3/dms3rep/multi/opt/Oil-Change-Header-1-1920w.jpg\" alt=\"Garage Work | Green Drop Garage\" id=\"1833102574\" class=\"\" data-dm-image-path=\"../irp.cdn-website.com/162ff4e3/dms3rep/multi/Oil-Change-Header-1.jpg\" width=\"955\" height=\"1440\" onerror=\"handleImageLo